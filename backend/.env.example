# ── BL-CRM Backend — copy to .env and fill in your values ───

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/blcrm?schema=public"

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development        # Change to "production" when deploying

# ── JWT Secrets — MUST be long random strings in production ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_use_a_64char_random_string
JWT_REFRESH_SECRET=CHANGE_ME_use_a_different_64char_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend URL (for CORS + email links) ────────────────────
# Comma-separated for multiple origins: https://app.example.com,https://www.example.com
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────────────
# Gmail: use an App Password (not your real password)
# Other: use any SMTP provider (Mailgun, SendGrid, Brevo, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587               # 587 for STARTTLS, 465 for SSL
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="BL-CRM <noreply@yourdomain.com>"
