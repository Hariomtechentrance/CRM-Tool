generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  avatar              String?
  isEmailVerified     Boolean              @default(false)
  emailVerifyToken    String?              @unique
  passwordResetToken  String?              @unique
  passwordResetExpiry DateTime?
  isSuperAdmin        Boolean              @default(false)
  twoFactorSecret     String?
  twoFactorEnabled    Boolean              @default(false)
  lastLoginAt         DateTime?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sentInvites         OrgInvite[]          @relation("InvitedBy")
  memberships         OrganizationMember[]
  refreshTokens       RefreshToken[]
  communications      Communication[]
  moduleAccess        UserModuleAccess[]
  accessRequests      AccessRequest[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Organization {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  businessType BusinessType         @default(IMPORT_EXPORT)
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String               @default("IN")
  pincode      String?
  currency     String               @default("INR")
  taxId        String?
  gstStateCode String?
  iecCode      String?
  panNumber    String?
  logo           String?
  website        String?
  enabledModules String[]           @default([])
  isActive       Boolean            @default(true)
  plan           String             @default("FREE")
  planExpiresAt  DateTime?
  adminNotes     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  invites        OrgInvite[]
  members        OrganizationMember[]
  parties        Party[]
  contacts       Contact[]
  communications Communication[]
  productCategories ProductCategory[]
  products       Product[]
  stockMovements StockMovement[]
  warehouses     Warehouse[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  shipments      Shipment[]
  invoices       Invoice[]
  payments       Payment[]
  employees      Employee[]
  attendances    Attendance[]
  payrolls       Payroll[]
  leaveRequests  LeaveRequest[]
  projects       Project[]
  tasks          Task[]
  leads          Lead[]
  campaigns      Campaign[]
  supportTickets SupportTicket[]
  tradeDocuments TradeDocument[]
  collections    Collection[]
  posSessions    POSSession[]
  stockTransfers    StockTransfer[]
  auditLogs         AuditLog[]
  userModuleAccess  UserModuleAccess[]
  accessRequests    AccessRequest[]
  goodsEntries      GoodsEntry[]
  emailLogs         EmailLog[]
  emailTemplates    EmailTemplate[]
  deals             Deal[]
  quotations        Quotation[]
  documents         Document[]
  notifications     Notification[]
  recurringInvoices RecurringInvoice[]
  leaveBalances     LeaveBalance[]
  productBatches    ProductBatch[]
  performanceGoals  PerformanceGoal[]
  performanceReviews PerformanceReview[]
  expenses          Expense[]
  shifts            Shift[]

  @@index([slug])
}

model UserModuleAccess {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  moduleKey      String
  grantedAt      DateTime     @default(now())
  grantedById    String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, moduleKey])
  @@index([organizationId])
  @@index([userId, organizationId])
}

model AccessRequest {
  id             String              @id @default(cuid())
  userId         String
  organizationId String
  moduleKey      String
  status         AccessRequestStatus @default(PENDING)
  message        String?
  responseNote   String?
  requestedAt    DateTime            @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, moduleKey])
  @@index([organizationId, status])
  @@index([userId])
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  userEmail      String?
  userName       String?
  action         String
  resource       String
  resourceId     String?
  description    String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
  @@index([userId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole   @default(STAFF)
  isActive       Boolean      @default(true)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrgInvite {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  role           MemberRole   @default(STAFF)
  allowedModules String[]
  token          String       @unique @default(cuid())
  status         InviteStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  ACCOUNTANT
  VIEWER
}

enum BusinessType {
  IMPORT
  EXPORT
  IMPORT_EXPORT
  TRADING
  MANUFACTURING
  RETAIL
  ECOMMERCE
  IT_SOFTWARE
  IT_SERVICES
  HEALTHCARE
  EDUCATION
  REAL_ESTATE
  FOOD_BEVERAGE
  LOGISTICS
  FINANCE
  CONSULTING
  MEDIA
  AGRICULTURE
  HOSPITALITY
  LEGAL
  NGO
  OTHER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum CommunicationType {
  CALL
  EMAIL
  MEETING
  NOTE
  WHATSAPP
}

// ─────────────────────────────────────────────────────────────
//  CRM — Parties (Customers & Suppliers)
// ─────────────────────────────────────────────────────────────

model Party {
  id             String    @id @default(cuid())
  organizationId String
  type           PartyType @default(CUSTOMER)
  name           String
  displayName    String?
  email          String?
  phone          String?
  mobile         String?
  website        String?

  // Address
  address        String?
  city           String?
  state          String?
  country        String?   @default("IN")
  pincode        String?

  // Business / Tax
  gstin          String?
  pan            String?
  iecCode        String?
  currency       String    @default("INR")
  creditLimit    Float?
  paymentTermsDays Int?

  // Banking
  bankName       String?
  bankAccount    String?
  bankIfsc       String?
  bankBranch     String?

  notes          String?
  tags           String[]  @default([])
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  communications Communication[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]
  goodsEntries   GoodsEntry[]
  payments       Payment[]
  leads          Lead[]
  supportTickets SupportTicket[]
  posSales       POSSale[]
  tradeDocuments TradeDocument[]
  projects       Project[]
  emailLogs      EmailLog[]
  deals              Deal[]
  quotations         Quotation[]
  recurringInvoices  RecurringInvoice[]

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, name])
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  partyId        String
  name           String
  designation    String?
  email          String?
  phone          String?
  mobile         String?
  isPrimary      Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party        @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
  @@index([organizationId])
}

model Communication {
  id             String            @id @default(cuid())
  organizationId String
  partyId        String
  type           CommunicationType @default(NOTE)
  subject        String?
  description    String
  outcome        String?
  followUpDate   DateTime?
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party        @relation(fields: [partyId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([partyId])
  @@index([organizationId, followUpDate])
}

// ─────────────────────────────────────────────────────────────
//  INVENTORY & STOCK
// ─────────────────────────────────────────────────────────────

enum MovementType {
  PURCHASE_IN
  SALES_OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
  OPENING_STOCK
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model ProductCategory {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  parentId       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     ProductCategory[] @relation("CategoryTree")
  products     Product[]

  @@index([organizationId])
}

model Product {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String?
  sku            String
  name           String
  description    String?
  unit           String        @default("PCS")
  costPrice      Float         @default(0)
  sellingPrice   Float         @default(0)
  mrp            Float?
  taxRate        Float         @default(0)
  hsnCode        String?
  reorderLevel   Float         @default(0)
  maxStockLevel  Float?
  currentStock   Float         @default(0)
  status         ProductStatus @default(ACTIVE)
  barcode        String?
  imageUrl       String?
  warehouseId    String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       ProductCategory? @relation(fields: [categoryId], references: [id])
  warehouse      Warehouse?       @relation(fields: [warehouseId], references: [id])
  stockMovements  StockMovement[]
  purchaseItems   PurchaseOrderItem[]
  salesItems      SalesOrderItem[]
  variants        ProductVariant[]
  posSaleItems    POSSaleItem[]
  quotationItems  QuotationItem[]
  batches         ProductBatch[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, categoryId])
}

model ProductBatch {
  id             String    @id @default(cuid())
  organizationId String
  productId      String
  batchNumber    String
  lotNumber      String?
  manufacturingDate DateTime?
  expiryDate     DateTime?
  quantity       Float     @default(0)
  costPrice      Float?
  notes          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId, batchNumber])
  @@index([organizationId])
  @@index([productId])
  @@index([expiryDate])
}

model StockMovement {
  id             String       @id @default(cuid())
  organizationId String
  productId      String
  warehouseId    String?
  type           MovementType
  quantity       Float
  balanceAfter   Float
  referenceType  String?
  referenceId    String?
  notes          String?
  createdById    String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id])

  @@index([organizationId])
  @@index([productId])
  @@index([organizationId, createdAt])
}

// ─────────────────────────────────────────────────────────────
//  WAREHOUSE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products        Product[]
  stockMovements  StockMovement[]
  transfersFrom   StockTransfer[] @relation("TransferFrom")
  transfersTo     StockTransfer[] @relation("TransferTo")
  goodsEntries    GoodsEntry[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model StockTransfer {
  id             String               @id @default(cuid())
  organizationId String
  fromWarehouseId String
  toWarehouseId  String
  status         StockTransferStatus  @default(DRAFT)
  transferDate   DateTime             @default(now())
  notes          String?
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromWarehouse  Warehouse    @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse    Warehouse    @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items          StockTransferItem[]

  @@index([organizationId])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Float
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

enum StockTransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────
//  PURCHASE & PROCUREMENT
// ─────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  organizationId String
  partyId        String?
  poNumber       String
  status         PurchaseOrderStatus @default(DRAFT)
  approvalStatus ApprovalStatus      @default(PENDING_APPROVAL)
  approvedById   String?
  approvalNote   String?
  approvedAt     DateTime?
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  warehouseId    String?
  subtotal       Float               @default(0)
  taxAmount      Float               @default(0)
  discount       Float               @default(0)
  total          Float               @default(0)
  notes          String?
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?             @relation(fields: [partyId], references: [id])
  items        PurchaseOrderItem[]

  @@unique([organizationId, poNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Float
  receivedQty     Float         @default(0)
  unitPrice       Float
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  total           Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────────────────────
//  SALES & DISPATCH
// ─────────────────────────────────────────────────────────────

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum ShipmentStatus {
  PENDING
  PACKED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

model SalesOrder {
  id             String          @id @default(cuid())
  organizationId String
  partyId        String?
  soNumber       String
  status         SalesOrderStatus @default(DRAFT)
  orderDate      DateTime         @default(now())
  expectedDate   DateTime?
  subtotal       Float            @default(0)
  taxAmount      Float            @default(0)
  discount       Float            @default(0)
  shippingCharge Float            @default(0)
  total          Float            @default(0)
  shippingAddress String?
  notes          String?
  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?           @relation(fields: [partyId], references: [id])
  items        SalesOrderItem[]
  shipments    Shipment[]
  invoices     Invoice[]

  @@unique([organizationId, soNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  productId    String?
  variantId    String?
  description  String
  quantity     Float
  dispatchedQty Float     @default(0)
  unitPrice    Float
  taxRate      Float      @default(0)
  taxAmount    Float      @default(0)
  discount     Float      @default(0)
  total        Float

  salesOrder SalesOrder      @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?        @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
}

model Shipment {
  id             String         @id @default(cuid())
  organizationId String
  salesOrderId   String?
  shipmentNumber String
  status         ShipmentStatus @default(PENDING)
  carrier        String?
  trackingNumber String?
  shipDate       DateTime?
  deliveryDate   DateTime?
  weight         Float?
  packages       Int            @default(1)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder?  @relation(fields: [salesOrderId], references: [id])

  @@unique([organizationId, shipmentNumber])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────
//  ACCOUNTS & FINANCE
// ─────────────────────────────────────────────────────────────

enum InvoiceType {
  SALES
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
  CARD
  OTHER
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  partyId        String?
  salesOrderId   String?
  type           InvoiceType   @default(SALES)
  status         InvoiceStatus @default(DRAFT)
  invoiceNumber  String
  invoiceDate    DateTime      @default(now())
  dueDate        DateTime?
  subtotal       Float         @default(0)
  taxAmount      Float         @default(0)
  discount       Float         @default(0)
  total          Float         @default(0)
  paidAmount     Float         @default(0)
  balanceDue     Float         @default(0)
  notes          String?
  terms          String?
  createdById    String?
  // GST fields
  placeOfSupply  String?
  reverseCharge  Boolean       @default(false)
  igstAmount     Float         @default(0)
  cgstAmount     Float         @default(0)
  sgstAmount     Float         @default(0)
  eInvoiceIRN    String?
  eWayBillNumber String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?        @relation(fields: [partyId], references: [id])
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, partyId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float   @default(0)
  taxAmount   Float   @default(0)
  discount    Float   @default(0)
  total       Float
  hsnCode     String?
  igstRate    Float   @default(0)
  igstAmount  Float   @default(0)
  cgstRate    Float   @default(0)
  cgstAmount  Float   @default(0)
  sgstRate    Float   @default(0)
  sgstAmount  Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  invoiceId      String?
  partyId        String?
  method         PaymentMethod @default(BANK_TRANSFER)
  amount         Float
  currency       String        @default("INR")
  referenceNumber String?
  paymentDate    DateTime      @default(now())
  notes          String?
  createdById    String?
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])
  party        Party?       @relation(fields: [partyId], references: [id])

  @@index([organizationId])
  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────
//  POINT OF SALE
// ─────────────────────────────────────────────────────────────

enum POSSessionStatus {
  OPEN
  CLOSED
}

model POSSession {
  id             String           @id @default(cuid())
  organizationId String
  warehouseId    String?
  status         POSSessionStatus @default(OPEN)
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  openingCash    Float            @default(0)
  closingCash    Float?
  totalSales     Float            @default(0)
  createdById    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        POSSale[]

  @@index([organizationId])
}

model POSSale {
  id             String   @id @default(cuid())
  organizationId String
  sessionId      String
  receiptNumber  String
  partyId        String?
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  discount       Float    @default(0)
  total          Float    @default(0)
  paidAmount     Float    @default(0)
  changeAmount   Float    @default(0)
  paymentMethod  PaymentMethod @default(CASH)
  notes          String?
  createdAt      DateTime @default(now())

  session  POSSession   @relation(fields: [sessionId], references: [id])
  party    Party?       @relation(fields: [partyId], references: [id])
  items    POSSaleItem[]

  @@index([organizationId])
  @@index([sessionId])
}

model POSSaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String?
  variantId String?
  name      String
  quantity  Float
  unitPrice Float
  taxRate   Float   @default(0)
  taxAmount Float   @default(0)
  discount  Float   @default(0)
  total     Float

  sale    POSSale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

// ─────────────────────────────────────────────────────────────
//  HR & PAYROLL
// ─────────────────────────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SalaryType {
  MONTHLY
  DAILY
}

model Employee {
  id             String         @id @default(cuid())
  organizationId String
  employeeCode   String
  name           String
  email          String?
  phone          String?
  designation    String?
  department     String?
  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)
  joiningDate    DateTime
  leavingDate    DateTime?
  salaryType     SalaryType     @default(MONTHLY)
  basicSalary    Float          @default(0)  // monthly CTC when salaryType=MONTHLY
  dailyRate      Float?                      // per-day rate when salaryType=DAILY
  hra            Float          @default(0)  // fixed monthly HRA component
  allowances     Float          @default(0)  // fixed monthly allowances
  bankAccount    String?
  bankIfsc       String?
  panNumber      String?
  pfNumber       String?
  esiNumber      String?
  address        String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  shiftId        String?

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shift            Shift?             @relation(fields: [shiftId], references: [id])
  attendances      Attendance[]
  payrolls         Payroll[]
  leaveRequests    LeaveRequest[]
  leaveBalances    LeaveBalance[]
  performanceGoals PerformanceGoal[]
  performanceReviews PerformanceReview[]
  expenses         Expense[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
}

model Attendance {
  id             String           @id @default(cuid())
  organizationId String
  employeeId     String
  date           DateTime
  status         AttendanceStatus @default(PRESENT)
  checkIn        DateTime?
  checkOut       DateTime?
  hoursWorked    Float?
  notes          String?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId])
  @@index([employeeId])
}

model Payroll {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  month          Int
  year           Int
  workingDays    Int      @default(26)
  presentDays    Float    @default(0)
  basicSalary    Float    @default(0)
  hra            Float    @default(0)
  allowances     Float    @default(0)
  deductions     Float    @default(0)
  pfDeduction    Float    @default(0)
  esiDeduction   Float    @default(0)
  grossSalary    Float    @default(0)
  netSalary      Float    @default(0)
  isPaid         Boolean  @default(false)
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([organizationId])
}

model LeaveRequest {
  id             String      @id @default(cuid())
  organizationId String
  employeeId     String
  leaveType      String      @default("Annual")
  fromDate       DateTime
  toDate         DateTime
  days           Float
  reason         String?
  status         LeaveStatus @default(PENDING)
  approvedById   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
}

model Shift {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  startTime      String
  endTime        String
  workingHours   Float    @default(8)
  graceMins      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@index([organizationId])
}

model LeaveBalance {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  year           Int
  leaveType      String
  allocated      Float    @default(0)
  used           Float    @default(0)
  pending        Float    @default(0)
  carried        Float    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, leaveType])
  @@index([organizationId])
}

model PerformanceGoal {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String
  title          String
  description    String?
  category       String    @default("Individual")
  targetDate     DateTime?
  progress       Int       @default(0)
  status         String    @default("IN_PROGRESS")
  year           Int
  quarter        Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
}

model PerformanceReview {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  reviewType     String   @default("ANNUAL")
  reviewPeriod   String
  rating         Float?
  selfRating     Float?
  status         String   @default("DRAFT")
  strengths      String?
  improvements   String?
  comments       String?
  reviewDate     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
}

model Expense {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String
  expenseDate    DateTime
  category       String
  title          String
  amount         Float
  currency       String    @default("INR")
  receiptUrl     String?
  status         String    @default("PENDING")
  notes          String?
  approvedById   String?
  approvedAt     DateTime?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId, status])
}

// ─────────────────────────────────────────────────────────────
//  PROJECTS & TASKS
// ─────────────────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  description    String?
  status         ProjectStatus @default(PLANNING)
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  partyId        String?
  managerId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?       @relation(fields: [partyId], references: [id])
  tasks        Task[]

  @@index([organizationId])
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assignedToId   String?
  dueDate        DateTime?
  completedAt    DateTime?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id])
  comments     TaskComment[]

  @@index([organizationId])
  @@index([projectId])
  @@index([organizationId, status])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  comment   String
  authorId  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─────────────────────────────────────────────────────────────
//  LEADS & MARKETING
// ─────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL
  PHONE
  EXHIBITION
  OTHER
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  name           String
  company        String?
  email          String?
  phone          String?
  source         LeadSource @default(OTHER)
  status         LeadStatus @default(NEW)
  value          Float?
  assignedToId   String?
  campaignId     String?
  notes          String?
  tags           String[]   @default([])
  score          Int        @default(0)
  convertedAt    DateTime?
  partyId        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?         @relation(fields: [partyId], references: [id])
  activities   LeadActivity[]
  campaign     Campaign?      @relation(fields: [campaignId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  description String
  createdById String?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Campaign {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String   @default("Email")
  status         String   @default("Draft")
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────
//  CUSTOMER SUPPORT
// ─────────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id             String         @id @default(cuid())
  organizationId String
  ticketNumber   String
  subject        String
  description    String
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  partyId        String?
  assignedToId   String?
  resolvedAt     DateTime?
  slaDeadline    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?        @relation(fields: [partyId], references: [id])
  replies      TicketReply[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  message   String
  isInternal Boolean @default(false)
  authorId  String?
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─────────────────────────────────────────────────────────────
//  IMPORT / EXPORT SUITE
// ─────────────────────────────────────────────────────────────

enum TradeDocumentType {
  BILL_OF_LADING
  LETTER_OF_CREDIT
  COMMERCIAL_INVOICE
  PACKING_LIST
  CERTIFICATE_OF_ORIGIN
  INSURANCE_CERTIFICATE
  SHIPPING_BILL
  BILL_OF_ENTRY
  OTHER
}

enum TradeDocumentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

model TradeDocument {
  id              String              @id @default(cuid())
  organizationId  String
  partyId         String?
  type            TradeDocumentType   @default(OTHER)
  status          TradeDocumentStatus @default(DRAFT)
  documentNumber  String
  documentDate    DateTime            @default(now())
  expiryDate      DateTime?
  country         String?
  portOfLoading   String?
  portOfDischarge String?
  vessel          String?
  flightNumber    String?
  amount          Float?
  currency        String              @default("USD")
  description     String?
  fileUrl         String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?       @relation(fields: [partyId], references: [id])

  @@unique([organizationId, documentNumber])
  @@index([organizationId])
  @@index([organizationId, type])
}

// ─────────────────────────────────────────────────────────────
//  RETAIL & FASHION (Clothing Brand)
// ─────────────────────────────────────────────────────────────

model Collection {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  season         String?
  year           Int?
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants     ProductVariant[]

  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────
//  STORE & DISPATCH REGISTER
// ─────────────────────────────────────────────────────────────

enum EntryDirection {
  INWARD
  OUTWARD
}

enum GoodsEntryStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model GoodsEntry {
  id             String           @id @default(cuid())
  organizationId String
  entryNumber    String
  direction      EntryDirection
  entryDate      DateTime
  entryTime      String?
  materialName   String
  quantity       Float
  unit           String           @default("PCS")
  partyName      String?
  partyId        String?
  vehicleNumber  String?
  personName     String?
  remarks        String?
  referenceNo    String?
  warehouseId    String?
  status         GoodsEntryStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party          Party?           @relation(fields: [partyId], references: [id])
  warehouse      Warehouse?       @relation(fields: [warehouseId], references: [id])

  @@unique([organizationId, entryNumber])
  @@index([organizationId, direction])
  @@index([organizationId, entryDate])
}

// ─────────────────────────────────────────────────────────────
//  DEALS / OPPORTUNITIES (Salesforce / HubSpot style)
// ─────────────────────────────────────────────────────────────

enum DealStage {
  PROSPECTING
  QUALIFICATION
  NEEDS_ANALYSIS
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Deal {
  id                String    @id @default(cuid())
  organizationId    String
  title             String
  partyId           String?
  leadId            String?
  stage             DealStage @default(PROSPECTING)
  value             Float?
  probability       Int       @default(20)
  expectedCloseDate DateTime?
  assignedToId      String?
  description       String?
  notes             String?
  closedAt          DateTime?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?       @relation(fields: [partyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, stage])
}

// ─────────────────────────────────────────────────────────────
//  QUOTATIONS / PROPOSALS (SAP / Odoo / Zoho style)
// ─────────────────────────────────────────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id              String          @id @default(cuid())
  organizationId  String
  quotationNumber String
  partyId         String?
  status          QuotationStatus @default(DRAFT)
  subject         String?
  validUntil      DateTime?
  subtotal        Float           @default(0)
  taxAmount       Float           @default(0)
  discount        Float           @default(0)
  total           Float           @default(0)
  notes           String?
  terms           String?
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?          @relation(fields: [partyId], references: [id])
  items        QuotationItem[]

  @@unique([organizationId, quotationNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model QuotationItem {
  id           String    @id @default(cuid())
  quotationId  String
  description  String
  quantity     Float     @default(1)
  unitPrice    Float
  taxRate      Float     @default(0)
  taxAmount    Float     @default(0)
  discount     Float     @default(0)
  total        Float
  productId    String?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────────────────────
//  EMAIL MODULE
// ─────────────────────────────────────────────────────────────

enum EmailStatus {
  DRAFT
  SENT
  FAILED
}

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  subject        String
  body           String   @db.Text
  category       String   @default("GENERAL")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emails       EmailLog[]

  @@index([organizationId])
}

model EmailLog {
  id             String      @id @default(cuid())
  organizationId String
  fromEmail      String
  toEmail        String
  ccEmail        String?
  subject        String
  body           String      @db.Text
  templateId     String?
  partyId        String?
  leadId         String?
  status         EmailStatus @default(SENT)
  errorMessage   String?
  sentAt         DateTime?
  sentById       String?
  createdAt      DateTime    @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?         @relation(fields: [partyId], references: [id])
  template     EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([organizationId])
  @@index([organizationId, partyId])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  collectionId String?
  sku          String
  size         String?
  color        String?
  material     String?
  costPrice    Float    @default(0)
  sellingPrice Float    @default(0)
  mrp          Float?
  stock        Float    @default(0)
  barcode      String?
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id])
  salesItems SalesOrderItem[]
  posSaleItems POSSaleItem[]

  @@unique([productId, sku])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
//  DOCUMENT ATTACHMENTS
// ─────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────
//  NOTIFICATIONS
// ─────────────────────────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  type           String
  title          String
  message        String
  link           String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([organizationId, isRead])
}

// ─────────────────────────────────────────────────────────────
//  RECURRING INVOICES
// ─────────────────────────────────────────────────────────────

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringInvoice {
  id             String             @id @default(cuid())
  organizationId String
  partyId        String?
  frequency      RecurringFrequency @default(MONTHLY)
  nextRunDate    DateTime
  dayOfMonth     Int                @default(1)
  subject        String?
  items          Json
  subtotal       Float              @default(0)
  taxAmount      Float              @default(0)
  total          Float              @default(0)
  notes          String?
  isActive       Boolean            @default(true)
  autoSend       Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?       @relation(fields: [partyId], references: [id])

  @@index([organizationId])
  @@index([nextRunDate, isActive])
}

model Document {
  id             String   @id @default(cuid())
  organizationId String
  fileName       String
  originalName   String
  mimeType       String
  fileSize       Int
  filePath       String

  entityType     String
  entityId       String
  description    String?

  uploadedById   String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
}
