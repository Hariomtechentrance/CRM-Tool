generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  avatar              String?
  isEmailVerified     Boolean              @default(false)
  emailVerifyToken    String?              @unique
  passwordResetToken  String?              @unique
  passwordResetExpiry DateTime?
  isSuperAdmin        Boolean              @default(false)
  twoFactorSecret     String?
  twoFactorEnabled    Boolean              @default(false)
  lastLoginAt         DateTime?
  isActive            Boolean              @default(true)
  loginAttempts       Int                  @default(0)
  lockedUntil         DateTime?
  lastPasswordChange  DateTime?
  passwordHistory     String[]             @default([])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sentInvites         OrgInvite[]          @relation("InvitedBy")
  memberships         OrganizationMember[]
  refreshTokens       RefreshToken[]
  sessions            UserSession[]
  apiKeys             ApiKey[]
  communications      Communication[]
  moduleAccess        UserModuleAccess[]
  accessRequests      AccessRequest[]
  gmailAccount        GmailAccount?
  emailAccounts       EmailAccount[]

  @@index([email])
}

model GmailAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  email        String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Universal multi-provider email accounts (Gmail OAuth, Outlook OAuth, IMAP/SMTP)
model EmailAccount {
  id           String        @id @default(cuid())
  userId       String
  provider     EmailProvider @default(GMAIL)
  label        String        // display name, e.g. "Work Gmail"
  email        String
  isPrimary    Boolean       @default(false)
  isActive     Boolean       @default(true)
  // OAuth tokens (Gmail, Outlook)
  accessToken  String?       @db.Text
  refreshToken String?       @db.Text
  expiresAt    DateTime?
  // IMAP/SMTP credentials (any provider)
  imapHost     String?
  imapPort     Int?
  imapSecure   Boolean       @default(true)
  smtpHost     String?
  smtpPort     Int?
  smtpSecure   Boolean       @default(true)
  smtpPassword String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
}

enum EmailProvider {
  GMAIL
  OUTLOOK
  YAHOO
  IMAP
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Organization {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  businessType BusinessType         @default(IMPORT_EXPORT)
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String               @default("IN")
  pincode      String?
  currency     String               @default("INR")
  taxId        String?
  gstStateCode String?
  iecCode      String?
  panNumber    String?
  logo             String?
  website          String?
  brandingColor    String?
  complianceConfig Json?
  enabledModules String[]           @default([])
  isActive       Boolean            @default(true)
  plan           String             @default("FREE")
  planExpiresAt  DateTime?
  adminNotes     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  invites        OrgInvite[]
  members        OrganizationMember[]
  parties        Party[]
  contacts       Contact[]
  communications Communication[]
  productCategories ProductCategory[]
  products       Product[]
  stockMovements StockMovement[]
  warehouses     Warehouse[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  shipments      Shipment[]
  invoices       Invoice[]
  payments       Payment[]
  employees      Employee[]
  attendances    Attendance[]
  payrolls       Payroll[]
  leaveRequests  LeaveRequest[]
  projects       Project[]
  tasks          Task[]
  leads          Lead[]
  campaigns      Campaign[]
  supportTickets SupportTicket[]
  tradeDocuments TradeDocument[]
  collections    Collection[]
  posSessions    POSSession[]
  stockTransfers    StockTransfer[]
  auditLogs         AuditLog[]
  userModuleAccess  UserModuleAccess[]
  accessRequests    AccessRequest[]
  goodsEntries      GoodsEntry[]
  emailLogs         EmailLog[]
  emailTemplates    EmailTemplate[]
  deals             Deal[]
  quotations        Quotation[]
  documents         Document[]
  notifications     Notification[]
  recurringInvoices RecurringInvoice[]
  leaveBalances     LeaveBalance[]
  productBatches    ProductBatch[]
  recordComments    RecordComment[]
  tdsEntries        TDSEntry[]
  budgets           Budget[]
  boms              BOM[]
  workOrders        WorkOrder[]
  exchangeRates     ExchangeRate[]
  bankTransactions  BankTransaction[]
  webhooks          WebhookEndpoint[]
  sprints           Sprint[]
  performanceGoals  PerformanceGoal[]
  performanceReviews PerformanceReview[]
  expenses          Expense[]
  shifts            Shift[]
  appointments      Appointment[]
  automationRules   LeadAutomationRule[]
  whatsappConfig    WhatsAppConfig?
  whatsappMessages  WhatsAppMessage[]
  leadForms         LeadForm[]
  apiKeys           ApiKey[]
  ipAllowlist       OrgIpAllowlist[]
  orgPermissions    OrgPermission[]

  // Phase 1 — IT Sector
  bugs                Bug[]
  projectTimeEntries  ProjectTimeEntry[]
  gitCommits          GitCommit[]
  slaPolicies         SLAPolicy[]
  resourceAllocations ResourceAllocation[]
  clientPortalUsers   ClientPortalUser[]

  // Phase 2 — Tele-calling
  callLogs        CallLog[]
  callScripts     CallScript[]
  dncEntries      DNCEntry[]
  dialerCampaigns DialerCampaign[]

  // Phase 3 — Services
  serviceCatalog    ServiceCatalogItem[]
  serviceContracts  ServiceContract[]
  kbArticles        KBArticle[]
  internalMessages  InternalMessage[]

  // Phase 4 — Stock Market
  advisoryPlans         AdvisoryPlan[]
  advisorySubscriptions AdvisorySubscription[]
  tradeCalls            TradeCall[]
  researchReports       ResearchReport[]
  kycRecords            KYCRecord[]
  marketAlerts          MarketAlert[]

  // Phase 5 — Health
  patients     Patient[]
  patientVisits PatientVisit[]
  prescriptions Prescription[]
  labReports   LabReport[]

  // Universal
  customFields CustomField[]
  smsLogs      SMSLog[]
  consentLogs  ConsentLog[]

  @@index([slug])
}

model UserModuleAccess {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  moduleKey      String
  grantedAt      DateTime     @default(now())
  grantedById    String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, moduleKey])
  @@index([organizationId])
  @@index([userId, organizationId])
}

model AccessRequest {
  id             String              @id @default(cuid())
  userId         String
  organizationId String
  moduleKey      String
  status         AccessRequestStatus @default(PENDING)
  message        String?
  responseNote   String?
  requestedAt    DateTime            @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, moduleKey])
  @@index([organizationId, status])
  @@index([userId])
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  userEmail      String?
  userName       String?
  action         String
  resource       String
  resourceId     String?
  description    String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
  @@index([userId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole   @default(STAFF)
  isActive       Boolean      @default(true)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrgInvite {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  role           MemberRole   @default(STAFF)
  allowedModules String[]
  token          String       @unique @default(cuid())
  status         InviteStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  ACCOUNTANT
  VIEWER
}

enum BusinessType {
  IMPORT
  EXPORT
  IMPORT_EXPORT
  TRADING
  MANUFACTURING
  RETAIL
  ECOMMERCE
  IT_SOFTWARE
  IT_SERVICES
  HEALTHCARE
  EDUCATION
  REAL_ESTATE
  FOOD_BEVERAGE
  LOGISTICS
  FINANCE
  CONSULTING
  MEDIA
  AGRICULTURE
  HOSPITALITY
  LEGAL
  NGO
  OTHER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum CommunicationType {
  CALL
  EMAIL
  MEETING
  NOTE
  WHATSAPP
}

// ─────────────────────────────────────────────────────────────
//  CRM — Parties (Customers & Suppliers)
// ─────────────────────────────────────────────────────────────

model Party {
  id             String    @id @default(cuid())
  organizationId String
  type           PartyType @default(CUSTOMER)
  name           String
  displayName    String?
  email          String?
  phone          String?
  mobile         String?
  website        String?

  // Address
  address        String?
  city           String?
  state          String?
  country        String?   @default("IN")
  pincode        String?

  // Business / Tax
  gstin          String?
  pan            String?
  iecCode        String?
  currency       String    @default("INR")
  creditLimit    Float?
  paymentTermsDays Int?

  // Banking
  bankName       String?
  bankAccount    String?
  bankIfsc       String?
  bankBranch     String?

  notes          String?
  tags           String[]  @default([])
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  communications Communication[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]
  goodsEntries   GoodsEntry[]
  payments       Payment[]
  leads          Lead[]
  supportTickets SupportTicket[]
  posSales       POSSale[]
  tradeDocuments TradeDocument[]
  projects       Project[]
  emailLogs      EmailLog[]
  deals              Deal[]
  quotations         Quotation[]
  recurringInvoices  RecurringInvoice[]
  tdsEntries         TDSEntry[]

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, name])
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  partyId        String
  name           String
  designation    String?
  email          String?
  phone          String?
  mobile         String?
  isPrimary      Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party        @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
  @@index([organizationId])
}

model Communication {
  id             String            @id @default(cuid())
  organizationId String
  partyId        String
  type           CommunicationType @default(NOTE)
  subject        String?
  description    String
  outcome        String?
  followUpDate   DateTime?
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party        @relation(fields: [partyId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([partyId])
  @@index([organizationId, followUpDate])
}

// ─────────────────────────────────────────────────────────────
//  INVENTORY & STOCK
// ─────────────────────────────────────────────────────────────

enum MovementType {
  PURCHASE_IN
  SALES_OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
  OPENING_STOCK
  PRODUCTION_IN
  PRODUCTION_USE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model ProductCategory {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  parentId       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     ProductCategory[] @relation("CategoryTree")
  products     Product[]

  @@index([organizationId])
}

model Product {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String?
  sku            String
  name           String
  description    String?
  unit           String        @default("PCS")
  costPrice      Float         @default(0)
  sellingPrice   Float         @default(0)
  mrp            Float?
  taxRate        Float         @default(0)
  hsnCode        String?
  reorderLevel   Float         @default(0)
  maxStockLevel  Float?
  currentStock   Float         @default(0)
  status         ProductStatus @default(ACTIVE)
  barcode        String?
  imageUrl       String?
  warehouseId    String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       ProductCategory? @relation(fields: [categoryId], references: [id])
  warehouse      Warehouse?       @relation(fields: [warehouseId], references: [id])
  stockMovements  StockMovement[]
  purchaseItems   PurchaseOrderItem[]
  salesItems      SalesOrderItem[]
  variants        ProductVariant[]
  posSaleItems    POSSaleItem[]
  quotationItems  QuotationItem[]
  batches         ProductBatch[]
  boms            BOM[]
  bomComponents   BOMItem[]        @relation("BOMComponents")

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, categoryId])
}

model ProductBatch {
  id             String    @id @default(cuid())
  organizationId String
  productId      String
  batchNumber    String
  lotNumber      String?
  manufacturingDate DateTime?
  expiryDate     DateTime?
  quantity       Float     @default(0)
  costPrice      Float?
  notes          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId, batchNumber])
  @@index([organizationId])
  @@index([productId])
  @@index([expiryDate])
}

model StockMovement {
  id             String       @id @default(cuid())
  organizationId String
  productId      String
  warehouseId    String?
  type           MovementType
  quantity       Float
  balanceAfter   Float
  referenceType  String?
  referenceId    String?
  notes          String?
  createdById    String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id])

  @@index([organizationId])
  @@index([productId])
  @@index([organizationId, createdAt])
}

// ─────────────────────────────────────────────────────────────
//  WAREHOUSE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products        Product[]
  stockMovements  StockMovement[]
  transfersFrom   StockTransfer[] @relation("TransferFrom")
  transfersTo     StockTransfer[] @relation("TransferTo")
  goodsEntries    GoodsEntry[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model StockTransfer {
  id             String               @id @default(cuid())
  organizationId String
  fromWarehouseId String
  toWarehouseId  String
  status         StockTransferStatus  @default(DRAFT)
  transferDate   DateTime             @default(now())
  notes          String?
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromWarehouse  Warehouse    @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse    Warehouse    @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items          StockTransferItem[]

  @@index([organizationId])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Float
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

enum StockTransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────
//  PURCHASE & PROCUREMENT
// ─────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  organizationId String
  partyId        String?
  poNumber       String
  status         PurchaseOrderStatus @default(DRAFT)
  approvalStatus ApprovalStatus      @default(PENDING_APPROVAL)
  approvedById   String?
  approvalNote   String?
  approvedAt     DateTime?
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  warehouseId    String?
  subtotal       Float               @default(0)
  taxAmount      Float               @default(0)
  discount       Float               @default(0)
  total          Float               @default(0)
  notes          String?
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?             @relation(fields: [partyId], references: [id])
  items        PurchaseOrderItem[]

  @@unique([organizationId, poNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Float
  receivedQty     Float         @default(0)
  unitPrice       Float
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  total           Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────────────────────
//  SALES & DISPATCH
// ─────────────────────────────────────────────────────────────

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum ShipmentStatus {
  PENDING
  PACKED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

model SalesOrder {
  id             String          @id @default(cuid())
  organizationId String
  partyId        String?
  soNumber       String
  status         SalesOrderStatus @default(DRAFT)
  orderDate      DateTime         @default(now())
  expectedDate   DateTime?
  subtotal       Float            @default(0)
  taxAmount      Float            @default(0)
  discount       Float            @default(0)
  shippingCharge Float            @default(0)
  total          Float            @default(0)
  shippingAddress String?
  notes          String?
  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?           @relation(fields: [partyId], references: [id])
  items        SalesOrderItem[]
  shipments    Shipment[]
  invoices     Invoice[]

  @@unique([organizationId, soNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  productId    String?
  variantId    String?
  description  String
  quantity     Float
  dispatchedQty Float     @default(0)
  unitPrice    Float
  taxRate      Float      @default(0)
  taxAmount    Float      @default(0)
  discount     Float      @default(0)
  total        Float

  salesOrder SalesOrder      @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?        @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
}

model Shipment {
  id             String         @id @default(cuid())
  organizationId String
  salesOrderId   String?
  shipmentNumber String
  status         ShipmentStatus @default(PENDING)
  carrier        String?
  trackingNumber String?
  shipDate       DateTime?
  deliveryDate   DateTime?
  weight         Float?
  packages       Int            @default(1)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder?  @relation(fields: [salesOrderId], references: [id])

  @@unique([organizationId, shipmentNumber])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────
//  ACCOUNTS & FINANCE
// ─────────────────────────────────────────────────────────────

enum InvoiceType {
  SALES
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
  CARD
  OTHER
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  partyId        String?
  salesOrderId   String?
  type           InvoiceType   @default(SALES)
  status         InvoiceStatus @default(DRAFT)
  invoiceNumber  String
  invoiceDate    DateTime      @default(now())
  dueDate        DateTime?
  subtotal       Float         @default(0)
  taxAmount      Float         @default(0)
  discount       Float         @default(0)
  total          Float         @default(0)
  paidAmount     Float         @default(0)
  balanceDue     Float         @default(0)
  notes          String?
  terms          String?
  createdById    String?
  // GST fields
  placeOfSupply  String?
  reverseCharge  Boolean       @default(false)
  igstAmount     Float         @default(0)
  cgstAmount     Float         @default(0)
  sgstAmount     Float         @default(0)
  eInvoiceIRN    String?
  eWayBillNumber String?
  publicToken    String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?        @relation(fields: [partyId], references: [id])
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, partyId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float   @default(0)
  taxAmount   Float   @default(0)
  discount    Float   @default(0)
  total       Float
  hsnCode     String?
  igstRate    Float   @default(0)
  igstAmount  Float   @default(0)
  cgstRate    Float   @default(0)
  cgstAmount  Float   @default(0)
  sgstRate    Float   @default(0)
  sgstAmount  Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  invoiceId      String?
  partyId        String?
  method         PaymentMethod @default(BANK_TRANSFER)
  amount         Float
  currency       String        @default("INR")
  referenceNumber String?
  paymentDate    DateTime      @default(now())
  notes          String?
  createdById    String?
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])
  party        Party?       @relation(fields: [partyId], references: [id])

  @@index([organizationId])
  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────
//  POINT OF SALE
// ─────────────────────────────────────────────────────────────

enum POSSessionStatus {
  OPEN
  CLOSED
}

model POSSession {
  id             String           @id @default(cuid())
  organizationId String
  warehouseId    String?
  status         POSSessionStatus @default(OPEN)
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  openingCash    Float            @default(0)
  closingCash    Float?
  totalSales     Float            @default(0)
  createdById    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        POSSale[]

  @@index([organizationId])
}

model POSSale {
  id             String   @id @default(cuid())
  organizationId String
  sessionId      String
  receiptNumber  String
  partyId        String?
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  discount       Float    @default(0)
  total          Float    @default(0)
  paidAmount     Float    @default(0)
  changeAmount   Float    @default(0)
  paymentMethod  PaymentMethod @default(CASH)
  notes          String?
  createdAt      DateTime @default(now())

  session  POSSession   @relation(fields: [sessionId], references: [id])
  party    Party?       @relation(fields: [partyId], references: [id])
  items    POSSaleItem[]

  @@index([organizationId])
  @@index([sessionId])
}

model POSSaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String?
  variantId String?
  name      String
  quantity  Float
  unitPrice Float
  taxRate   Float   @default(0)
