  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

// ─────────────────────────────────────────────────────────────
//  HR & PAYROLL
// ─────────────────────────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SalaryType {
  MONTHLY
  DAILY
}

model Employee {
  id             String         @id @default(cuid())
  organizationId String
  employeeCode   String
  name           String
  email          String?
  phone          String?
  designation    String?
  department     String?
  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)
  joiningDate    DateTime
  leavingDate    DateTime?
  salaryType     SalaryType     @default(MONTHLY)
  basicSalary    Float          @default(0)  // monthly CTC when salaryType=MONTHLY
  dailyRate      Float?                      // per-day rate when salaryType=DAILY
  hra            Float          @default(0)  // fixed monthly HRA component
  allowances     Float          @default(0)  // fixed monthly allowances
  bankAccount    String?
  bankIfsc       String?
  panNumber      String?
  pfNumber       String?
  esiNumber      String?
  address        String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  shiftId        String?

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shift            Shift?             @relation(fields: [shiftId], references: [id])
  attendances      Attendance[]
  payrolls         Payroll[]
  leaveRequests    LeaveRequest[]
  leaveBalances    LeaveBalance[]
  performanceGoals PerformanceGoal[]
  performanceReviews PerformanceReview[]
  expenses         Expense[]
  projectMembers   ProjectMember[]
  timeLogs         TimeLog[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
}

model Attendance {
  id             String           @id @default(cuid())
  organizationId String
  employeeId     String
  date           DateTime
  status         AttendanceStatus @default(PRESENT)
  checkIn        DateTime?
  checkOut       DateTime?
  hoursWorked    Float?
  notes          String?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId])
  @@index([employeeId])
}

model Payroll {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  month          Int
  year           Int
  workingDays    Int      @default(26)
  presentDays    Float    @default(0)
  basicSalary    Float    @default(0)
  hra            Float    @default(0)
  allowances     Float    @default(0)
  deductions     Float    @default(0)
  pfDeduction    Float    @default(0)
  esiDeduction   Float    @default(0)
  grossSalary    Float    @default(0)
  netSalary      Float    @default(0)
  isPaid         Boolean  @default(false)
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([organizationId])
}

model LeaveRequest {
  id             String      @id @default(cuid())
  organizationId String
  employeeId     String
  leaveType      String      @default("Annual")
  fromDate       DateTime
  toDate         DateTime
  days           Float
  reason         String?
  status         LeaveStatus @default(PENDING)
  approvedById   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
}

model Shift {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  startTime      String
  endTime        String
  workingHours   Float    @default(8)
  graceMins      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@index([organizationId])
}

model LeaveBalance {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  year           Int
  leaveType      String
  allocated      Float    @default(0)
  used           Float    @default(0)
  pending        Float    @default(0)
  carried        Float    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, leaveType])
  @@index([organizationId])
}

model PerformanceGoal {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String
  title          String
  description    String?
  category       String    @default("Individual")
  targetDate     DateTime?
  progress       Int       @default(0)
  status         String    @default("IN_PROGRESS")
  year           Int
  quarter        Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
}

model PerformanceReview {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  reviewType     String   @default("ANNUAL")
  reviewPeriod   String
  rating         Float?
  selfRating     Float?
  status         String   @default("DRAFT")
  strengths      String?
  improvements   String?
  comments       String?
  reviewDate     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
}

model Expense {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String
  expenseDate    DateTime
  category       String
  title          String
  amount         Float
  currency       String    @default("INR")
  receiptUrl     String?
  status         String    @default("PENDING")
  notes          String?
  approvedById   String?
  approvedAt     DateTime?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId, status])
}

// ─────────────────────────────────────────────────────────────
//  PROJECTS & TASKS
// ─────────────────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  description    String?
  status         ProjectStatus @default(PLANNING)
  projectType    ITProjectType @default(OTHER)
  priority       TaskPriority  @default(MEDIUM)
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  clientName     String?
  techStack      String[]      @default([])
  repoUrl        String?
  liveUrl        String?
  totalEstHours  Float?
  completionPct    Int           @default(0)
  publicToken      String?       @unique
  publicSharedAt   DateTime?
  partyId          String?
  managerId        String?
  createdById      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party               Party?              @relation(fields: [partyId], references: [id])
  tasks               Task[]
  members             ProjectMember[]
  milestones          ProjectMilestone[]
  sprints             Sprint[]
  bugs                Bug[]
  timeEntries         ProjectTimeEntry[]
  gitCommits          GitCommit[]
  resourceAllocations ResourceAllocation[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String?
  sprintId       String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assignedToId   String?
  storyPoints    Int?
  estimatedHours Float?
  actualHours    Float?
  tags           String[]     @default([])
  dueDate        DateTime?
  completedAt    DateTime?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id])
  sprint       Sprint?      @relation(fields: [sprintId], references: [id])
  comments     TaskComment[]
  timeLogs     TimeLog[]

  @@index([organizationId])
  @@index([projectId])
  @@index([sprintId])
  @@index([organizationId, status])
  @@index([assignedToId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  comment   String
  authorId  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─────────────────────────────────────────────────────────────
//  LEADS & MARKETING
// ─────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL
  PHONE
  EXHIBITION
  OTHER
}

model Lead {
  id               String     @id @default(cuid())
  organizationId   String
  name             String
  company          String?
  email            String?
  phone            String?
  phone2           String?
  city             String?
  industry         String?
  source           LeadSource @default(OTHER)
  status           LeadStatus @default(NEW)
  value            Float?
  assignedToId     String?
  campaignId       String?
  notes            String?
  tags             String[]   @default([])
  score            Int        @default(0)
  leadGrade        String?
  isDoNotCall      Boolean    @default(false)
  nextFollowUpDate DateTime?
  lastContactedAt  DateTime?
  convertedAt      DateTime?
  partyId          String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party             Party?            @relation(fields: [partyId], references: [id])
  activities        LeadActivity[]
  campaign          Campaign?         @relation(fields: [campaignId], references: [id])
  appointments      Appointment[]
  whatsappMessages  WhatsAppMessage[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([organizationId, nextFollowUpDate])
}

model LeadActivity {
  id           String    @id @default(cuid())
  leadId       String
  type         String
  subject      String?
  description  String
  outcome      String?
  callOutcome  String?
  duration     Int?
  followUpDate DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([followUpDate])
}

model Appointment {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?
  partyId        String?
  title          String
  description    String?
  scheduledAt    DateTime
  duration       Int      @default(30)
  location       String?
  meetingLink    String?
  status         String   @default("SCHEDULED")
  outcome        String?
  assignedToId   String?
  remindAt       DateTime?
  reminderSent   Boolean  @default(false)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id])

  @@index([organizationId])
  @@index([scheduledAt])
  @@index([leadId])
}

model LeadAutomationRule {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isActive       Boolean  @default(true)
  trigger        String
  triggerValue   String?
  actionType     String
  actionConfig   Json     @default("{}")
  executionCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Campaign {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String   @default("Email")
  status         String   @default("Draft")
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────
//  CUSTOMER SUPPORT
// ─────────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id             String         @id @default(cuid())
  organizationId String
  ticketNumber   String
  subject        String
  description    String
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  partyId        String?
  assignedToId   String?
  slaPolicyId    String?
  resolvedAt     DateTime?
  slaDeadline    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?       @relation(fields: [partyId], references: [id])
  slaPolicy    SLAPolicy?   @relation(fields: [slaPolicyId], references: [id])
  replies      TicketReply[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  message   String
  isInternal Boolean @default(false)
  authorId  String?
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─────────────────────────────────────────────────────────────
//  IMPORT / EXPORT SUITE
// ─────────────────────────────────────────────────────────────

enum TradeDocumentType {
  BILL_OF_LADING
  LETTER_OF_CREDIT
  COMMERCIAL_INVOICE
  PACKING_LIST
  CERTIFICATE_OF_ORIGIN
  INSURANCE_CERTIFICATE
  SHIPPING_BILL
  BILL_OF_ENTRY
  OTHER
}

enum TradeDocumentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

model TradeDocument {
  id              String              @id @default(cuid())
  organizationId  String
  partyId         String?
  type            TradeDocumentType   @default(OTHER)
  status          TradeDocumentStatus @default(DRAFT)
  documentNumber  String
  documentDate    DateTime            @default(now())
  expiryDate      DateTime?
  country         String?
  portOfLoading   String?
  portOfDischarge String?
  vessel          String?
  flightNumber    String?
  amount          Float?
  currency        String              @default("USD")
  description     String?
  fileUrl         String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?       @relation(fields: [partyId], references: [id])

  @@unique([organizationId, documentNumber])
  @@index([organizationId])
  @@index([organizationId, type])
}

// ─────────────────────────────────────────────────────────────
