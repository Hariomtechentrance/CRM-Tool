  organizationId String
  entryNumber    String
  direction      EntryDirection
  entryDate      DateTime
  entryTime      String?
  materialName   String
  quantity       Float
  unit           String           @default("PCS")
  partyName      String?
  partyId        String?
  vehicleNumber  String?
  personName     String?
  remarks        String?
  referenceNo    String?
  warehouseId    String?
  status         GoodsEntryStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

