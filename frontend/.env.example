# ── BL-CRM Frontend Environment ─────────────────────────────
# Copy to .env.local for local development
# In production this is handled by the Docker/nginx build

# API base URL (only needed if NOT using Vite proxy, e.g. standalone deployment)
# VITE_API_URL=https://api.yourdomain.com

# App name (shown in browser tab)
VITE_APP_NAME=BL-CRM
