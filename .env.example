# ── BL-CRM Docker Compose Environment ────────────────────────
# Copy to .env and fill in your values before running docker-compose up

# ── Database ─────────────────────────────────────────────────
# Password for the PostgreSQL container (also used in DATABASE_URL)
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT Secrets — MUST be long random strings ─────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64char_random_string_here
JWT_REFRESH_SECRET=CHANGE_ME_different_64char_random_string

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App URL ───────────────────────────────────────────────────
# The public URL users access (used for CORS + email links)
FRONTEND_URL=http://localhost

# ── Port ─────────────────────────────────────────────────────
APP_PORT=80

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=BL-CRM <noreply@yourdomain.com>
