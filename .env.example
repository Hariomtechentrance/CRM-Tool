# ── FlowCRM Environment Configuration ─────────────────────────
# Copy this file to backend/.env and fill in your values

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────
# Local: postgresql://postgres:password@localhost:5432/flowcrm
# Render/Supabase/Neon: paste your connection string here
DATABASE_URL=postgresql://postgres:password@localhost:5432/flowcrm

# ── JWT Secrets — MUST be long random strings ─────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_generate_64char_random_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_different_64char_random_string

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS — Frontend origin ────────────────────────────────────
# Local dev: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────────────
# Gmail: enable 2FA and create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=FlowCRM <noreply@yourdomain.com>

# ── AI Chatbot (Groq — free tier) ───────────────────────────
# Get free API key at: https://console.groq.com/keys
# Model: llama-3.3-70b-versatile (14,400 free requests/day)
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# ── Docker Compose only ───────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
APP_PORT=80
